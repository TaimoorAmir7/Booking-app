DJANGO_SECRET_KEY=dev-secret-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Local testing: SQLite (no Postgres required)
USE_SQLITE=True
# SQLITE_PATH=db.sqlite3
# Railway (optional volume mounted at /data): SQLITE_PATH=/data/db.sqlite3

# Production: set USE_SQLITE=False and provide Postgres URL
# USE_SQLITE=False
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appointment_assistant

CORS_ALLOWED_ORIGINS=http://localhost:3000
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
